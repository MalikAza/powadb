{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-frontend.sh\"",
            "asyncRewake": true,
            "timeout": 120,
            "statusMessage": "Checking frontend (biome + tsc)"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-backend.sh\"",
            "asyncRewake": true,
            "timeout": 300,
            "statusMessage": "Checking backend (cargo fmt + check + clippy)"
          }
        ]
      }
    ]
  }
}
